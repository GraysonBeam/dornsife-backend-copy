# Local development environment variables.
# Copy this file to .env before running the backend: 
# cp env.example .env
# .env is NOT committed to source control.
# The app loads it automatically via python-dotenv.

# Format: postgresql://username:password@host:port/database
DORNSIFE_DATABASE_URL=postgresql://user:password@localhost:5433/dornsife_db

# Time-to-live for verification codes in minutes
VERIFICATION_TTL=15

# API key from SendGrid dashboard
SENDGRID_API_KEY=your_sendgrid_api_key_here

# Email address that will appear as the sender
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# SendGrid template ID for verification emails
SENDGRID_VERIFICATION_TEMPLATE_ID=your_template_id_here

# For development only
SEND_VERIFICATION_MESSAGES=False

TWILIO_API_KEY=your_twilio_api_key_here
TWILIO_API_SECRET=your_twilio_api_secret_here
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_VERIFY_SERVICE_SID=your_twilio_verify_service_sid_here

# Log level
LOG_LEVEL=DEBUG